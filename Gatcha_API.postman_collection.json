							"mode": "raw",
							"raw": "{\n    \"username\": \"alice\",\n    \"password\": \"alice\"\n}"
						},
						"url": {
							"raw": "http://localhost:8081/api/auth/register",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8081",
							"path": ["api", "auth", "register"]
						}
					}
				},
				{
					"name": "Login (bob)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"bob\",\n    \"password\": \"bob\"\n}"
						},
						"url": {
							"raw": "http://localhost:8081/api/auth/login",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8081",
							"path": ["api", "auth", "login"]
						}
					}
				},
				{
					"name": "Login (alice)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"alice\",\n    \"password\": \"alice\"\n}"
						},
						"url": {
							"raw": "http://localhost:8081/api/auth/login",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8081",
							"path": ["api", "auth", "login"]
						}
					}
				},
				{
					"name": "Validate Token",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8081/api/auth/validate?token={{token}}",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8081",
							"path": ["api", "auth", "validate"],
							"query": [
								{
									"key": "token",
									"value": "{{token}}"
								}
							]
						}
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "http://localhost:8081/api/auth/logout?token={{token}}",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8081",
							"path": ["api", "auth", "logout"],
							"query": [
								{
									"key": "token",
									"value": "{{token}}"
								}
							]
						}
					}
				}
			]
		},
