	"item": [
		{
			"name": "1. Auth API",
			"item": [
				{
					"name": "Register (bob)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"bob\",\n    \"password\": \"bob\"\n}"
						},
						"url": {
							"raw": "http://localhost:8081/api/auth/register",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8081",
							"path": ["api", "auth", "register"]
						}
					}
				},
				{
					"name": "Register (alice)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
