						"body": {
							"mode": "raw",
							"raw": "{\n    \"monster1\": {\n        \"playerName\": \"bob\",\n        \"element\": \"fire\",\n        \"hp\": 1200,\n        \"atk\": 450,\n        \"def\": 300,\n        \"vit\": 85,\n        \"skills\": [\n            {\n                \"num\": 1,\n                \"dmg\": 125,\n                \"ratioStat\": \"atk\",\n                \"ratioPercent\": 25,\n                \"cooldown\": 0\n            },\n            {\n                \"num\": 2,\n                \"dmg\": 250,\n                \"ratioStat\": \"atk\",\n                \"ratioPercent\": 27.5,\n                \"cooldown\": 2\n            },\n            {\n                \"num\": 3,\n                \"dmg\": 425,\n                \"ratioStat\": \"atk\",\n                \"ratioPercent\": 40,\n                \"cooldown\": 5\n            }\n        ]\n    },\n    \"monster2\": {\n        \"playerName\": \"alice\",\n        \"element\": \"water\",\n        \"hp\": 1400,\n        \"atk\": 350,\n        \"def\": 400,\n        \"vit\": 75,\n        \"skills\": [\n            {\n                \"num\": 1,\n                \"dmg\": 80,\n                \"ratioStat\": \"def\",\n                \"ratioPercent\": 40,\n                \"cooldown\": 0\n            },\n            {\n                \"num\": 2,\n                \"dmg\": 120,\n                \"ratioStat\": \"def\",\n                \"ratioPercent\": 60,\n                \"cooldown\": 2\n            },\n            {\n                \"num\": 3,\n                \"dmg\": 180,\n                \"ratioStat\": \"hp\",\n                \"ratioPercent\": 10,\n                \"cooldown\": 3\n            }\n        ]\n    }\n}"
						},
